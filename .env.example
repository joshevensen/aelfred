# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# For Docker Compose: use "postgres" as the host (the service name in docker-compose.yml)
# For direct local use (DBngin, Homebrew): use "localhost"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aelfred

# DigitalOcean Inference Engine
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_INFERENCE_API_KEY=

# Model tier identifiers
DO_MODEL_SMALL=
DO_MODEL_MID=
DO_MODEL_FRONTIER=
