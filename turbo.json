{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "dist/**",
        ".mastra/output/**"
      ],
      "env": [
        "DATABASE_URL",
        "DO_INFERENCE_BASE_URL",
        "DO_INFERENCE_API_KEY",
        "DO_MODEL_SMALL",
        "DO_MODEL_MID",
        "DO_MODEL_FRONTIER"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "DATABASE_URL",
        "DO_INFERENCE_BASE_URL",
        "DO_INFERENCE_API_KEY",
        "DO_MODEL_SMALL",
        "DO_MODEL_MID",
        "DO_MODEL_FRONTIER"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
